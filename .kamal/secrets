# Secrets pulled at deploy time. None of these values should be committed.
# All inputs come from files outside the repo (~/.kamal/*) or from the
# committed-but-encrypted config/master.key.

# ghcr.io PAT with write:packages, read:packages scopes.
# Create at https://github.com/settings/tokens (classic).
# Store at: echo "<token>" > ~/.kamal/ghcr-token && chmod 600 ~/.kamal/ghcr-token
KAMAL_REGISTRY_PASSWORD=$(cat ~/.kamal/ghcr-token)

# Rails master key — decrypts config/credentials.yml.enc (which holds
# capture_api_key and basic_auth.user/pass). Never commit master.key.
RAILS_MASTER_KEY=$(cat config/master.key)

# Postgres password for the db accessory.
# Generate once: openssl rand -hex 32 > ~/.kamal/discord-demo-pg-password
# chmod 600 ~/.kamal/discord-demo-pg-password
POSTGRES_PASSWORD=$(cat ~/.kamal/discord-demo-pg-password)
