{
  "manifest_version": 3,
  "name": "Discord DM Capture",
  "version": "0.2.0",
  "description": "Mirrors inbound Discord gateway frames to the sourcing dashboard. Receives-only in v1.",
  "permissions": [
    "storage",
    "alarms",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://*.discord.com/*",
    "https://sneaker.campoli.me/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*", "https://*.discord.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://discord.com/*", "https://*.discord.com/*"],
      "js": ["inject.bundle.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Discord DM Capture — open side panel",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
