<% content_for :title, "Orders" %>

<%= render "shared/nav" %>

<header class="mb-4">
  <h1 class="text-xl font-semibold tracking-tight">Orders</h1>
  <p class="text-xs text-slate-500 mt-0.5"><%= pluralize(Order.count, "order") %> total</p>
</header>

<form method="get" class="mb-4 flex flex-wrap gap-2">
  <input type="text" name="q" value="<%= @q %>"
         placeholder="Search email, product name or SKU…"
         class="flex-1 min-w-48 rounded border border-slate-300 bg-white px-3 py-1.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400">
  <select name="status"
          class="rounded border border-slate-300 bg-white px-2 py-1.5 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400">
    <option value="">All statuses</option>
    <% @statuses.each do |s| %>
      <option value="<%= s %>" <%= "selected" if @status == s %>><%= s %></option>
    <% end %>
  </select>
  <button type="submit"
          class="rounded bg-slate-800 px-3 py-1.5 text-sm text-white hover:bg-slate-700">Filter</button>
  <% if @q.present? || @status.present? %>
    <%= link_to "Clear", orders_path, class: "rounded border border-slate-300 px-3 py-1.5 text-sm text-slate-600 hover:bg-slate-50" %>
  <% end %>
</form>

<div class="overflow-x-auto rounded border border-slate-200 bg-white">
  <table class="w-full text-sm">
    <thead class="border-b border-slate-200 bg-slate-50 text-xs text-slate-500">
      <tr>
        <th class="px-3 py-2 text-left font-medium">#</th>
        <th class="px-3 py-2 text-left font-medium">Date</th>
        <th class="px-3 py-2 text-left font-medium">Product</th>
        <th class="px-3 py-2 text-left font-medium">SKU</th>
        <th class="px-3 py-2 text-left font-medium">Size</th>
        <th class="px-3 py-2 text-right font-medium">Price</th>
        <th class="px-3 py-2 text-left font-medium">Status</th>
        <th class="px-3 py-2 text-left font-medium">Customer</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% if @orders.any? %>
        <% @orders.each do |order| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-3 py-2 font-mono text-xs text-slate-500"><%= order.order_number %></td>
            <td class="px-3 py-2 text-slate-500 whitespace-nowrap">
              <%= order.ordered_at&.strftime("%-d %b %Y") || "—" %>
            </td>
            <td class="px-3 py-2 max-w-xs">
              <%= link_to order.product.name, product_path(order.product),
                    class: "text-slate-800 hover:underline truncate block" %>
            </td>
            <td class="px-3 py-2 font-mono text-xs text-slate-500"><%= order.product.sku %></td>
            <td class="px-3 py-2 text-slate-700"><%= order.size %></td>
            <td class="px-3 py-2 text-right font-medium tabular-nums">
              <% if order.sold_price_cents %>
                €<%= format("%.2f", order.sold_price_cents / 100.0) %>
              <% else %>
                <span class="text-slate-400">—</span>
              <% end %>
            </td>
            <td class="px-3 py-2">
              <% status_color = case order.status
                   when "completed"                        then "bg-emerald-50 text-emerald-700"
                   when /cancel/                           then "bg-red-50 text-red-700"
                   when /no.stock|not.in|urgent|reorder/  then "bg-amber-50 text-amber-700"
                   else                                        "bg-slate-100 text-slate-600"
                   end %>
              <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium <%= status_color %>">
                <%= order.status %>
              </span>
            </td>
            <td class="px-3 py-2 text-xs text-slate-500 max-w-[160px] truncate">
              <%= order.customer_email.presence || "—" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="8" class="px-3 py-8 text-center text-sm text-slate-400 italic">No orders found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.last > 1 %>
  <div class="mt-4 flex items-center gap-2 text-sm">
    <% if @pagy.previous %>
      <%= link_to "← Prev", orders_path(page: @pagy.previous, q: @q, status: @status),
            class: "rounded border border-slate-300 px-3 py-1.5 hover:bg-slate-50" %>
    <% end %>
    <span class="text-slate-500">Page <%= @pagy.page %> of <%= @pagy.last %></span>
    <% if @pagy.next %>
      <%= link_to "Next →", orders_path(page: @pagy.next, q: @q, status: @status),
            class: "rounded border border-slate-300 px-3 py-1.5 hover:bg-slate-50" %>
    <% end %>
  </div>
<% end %>
