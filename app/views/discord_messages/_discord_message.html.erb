<article id="<%= dom_id(message) %>" class="bg-white border border-slate-200 rounded p-3 flex gap-3 text-sm">
  <div class="text-xs text-slate-400 font-mono tabular-nums shrink-0 w-20 pt-0.5">
    <time datetime="<%= message.captured_at.iso8601 %>" title="<%= message.captured_at.iso8601 %>">
      <%= message.captured_at.strftime("%H:%M:%S") %>
    </time>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-baseline gap-2 mb-0.5">
      <span class="font-medium text-slate-900">
        <%= message.author_display_name.presence || message.author_username.presence || "(unknown)" %>
      </span>
      <% if message.author_username.present? && message.author_username != message.author_display_name %>
        <span class="text-xs text-slate-400">@<%= message.author_username %></span>
      <% end %>
      <span class="text-xs text-slate-500 ml-auto shrink-0">
        <%= message.display_channel_name %>
      </span>
    </div>

    <%# Reply quote — Discord inlines the referenced message for replies %>
    <% if (reply = message.reply_context) %>
      <div class="mb-2 pl-2 border-l-2 border-slate-300 text-xs text-slate-500">
        <div>
          replying to
          <span class="font-medium text-slate-600">@<%= reply.author_display %></span>
        </div>
        <% if reply.content.present? %>
          <div class="text-slate-600 whitespace-pre-wrap break-words italic">
            <%= truncate(reply.content, length: 200) %>
          </div>
        <% elsif reply.has_attachments? %>
          <div class="italic text-slate-400">(attachment)</div>
        <% end %>
      </div>
    <% end %>

    <% if message.content.present? %>
      <div class="text-slate-700 whitespace-pre-wrap break-words">
        <%= truncate(message.content, length: 800) %>
      </div>
    <% elsif !message.renderable_body? %>
      <div class="text-xs text-slate-400 italic">(no content)</div>
    <% end %>

    <%# Attachments: render images inline, everything else as a file link %>
    <% if message.attachments.any? %>
      <div class="mt-2 flex flex-wrap gap-2">
        <% message.attachments.each do |att| %>
          <% if att.image? && att.url.present? %>
            <a href="<%= att.url %>" target="_blank" rel="noopener noreferrer"
               class="block shrink-0 overflow-hidden rounded border border-slate-200 bg-slate-50">
              <img src="<%= att.url %>"
                   alt="<%= att.filename %>"
                   loading="lazy"
                   class="max-h-72 max-w-full object-contain block">
            </a>
          <% else %>
            <a href="<%= att.url %>" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-2 py-1 rounded border border-slate-200 bg-slate-50 hover:bg-slate-100 text-slate-700 text-xs">
              <span aria-hidden="true">📎</span>
              <span class="font-medium"><%= att.filename %></span>
              <% if att.human_size %>
                <span class="text-slate-400">(<%= att.human_size %>)</span>
              <% end %>
            </a>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Stickers: render the PNG/GIF from Discord's CDN %>
    <% if message.stickers.any? %>
      <div class="mt-2 flex flex-wrap gap-2">
        <% message.stickers.each do |s| %>
          <% if s.renderable_as_image? %>
            <img src="<%= s.url %>"
                 alt="sticker: <%= s.name %>"
                 title="<%= s.name %>"
                 loading="lazy"
                 class="w-24 h-24 object-contain">
          <% else %>
            <span class="text-xs text-slate-400 italic">(sticker: <%= s.name %>)</span>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Rich embeds (bot announcements, link previews, Tenor GIFs).
        Skip empty placeholder embeds (Discord sometimes sends one when
        a URL is detected but unfurling returned nothing). %>
    <% if (visible_embeds = message.embeds.select(&:any_content?)).any? %>
      <div class="mt-2 flex flex-col gap-2">
        <% visible_embeds.each do |embed| %>
          <div class="rounded border border-slate-200 bg-slate-50 overflow-hidden"
               style="<%= "border-left: 3px solid #{embed.color_hex};" if embed.color_hex %>">
            <div class="p-3 flex gap-3">
              <div class="flex-1 min-w-0">
                <% if embed.author_name.present? %>
                  <div class="text-xs text-slate-500 mb-1">
                    <% if embed.author_url.present? %>
                      <a href="<%= embed.author_url %>" target="_blank" rel="noopener noreferrer"
                         class="hover:underline"><%= embed.author_name %></a>
                    <% else %>
                      <%= embed.author_name %>
                    <% end %>
                  </div>
                <% end %>

                <% if embed.title.present? %>
                  <div class="font-medium text-slate-900 mb-1">
                    <% if embed.url.present? %>
                      <a href="<%= embed.url %>" target="_blank" rel="noopener noreferrer"
                         class="text-blue-700 hover:underline"><%= embed.title %></a>
                    <% else %>
                      <%= embed.title %>
                    <% end %>
                  </div>
                <% end %>

                <% if embed.description.present? %>
                  <div class="text-sm text-slate-700 whitespace-pre-wrap break-words mb-2">
                    <%= truncate(embed.description, length: 800) %>
                  </div>
                <% end %>

                <% if embed.fields.any? %>
                  <%# Inline fields side-by-side, non-inline full-width.
                      Group consecutive inline fields into a flex row. %>
                  <div class="mt-2 flex flex-wrap gap-x-4 gap-y-2 text-xs">
                    <% embed.fields.each do |field| %>
                      <div class="<%= field.inline ? 'min-w-[8rem]' : 'basis-full' %>">
                        <div class="font-semibold text-slate-800"><%= field.name %></div>
                        <div class="text-slate-700 whitespace-pre-wrap break-words"><%= field.value %></div>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <% if embed.image_url.present? %>
                  <a href="<%= embed.image_url %>" target="_blank" rel="noopener noreferrer"
                     class="block mt-2 overflow-hidden rounded border border-slate-200">
                    <img src="<%= embed.image_url %>"
                         alt="<%= embed.title.to_s %>"
                         loading="lazy"
                         class="max-h-72 max-w-full object-contain block">
                  </a>
                <% end %>

                <% if embed.footer_text.present? || embed.timestamp.present? %>
                  <div class="text-xs text-slate-400 mt-2">
                    <%= embed.footer_text %>
                    <% if embed.footer_text.present? && embed.timestamp.present? %> · <% end %>
                    <%= embed.timestamp %>
                  </div>
                <% end %>
              </div>

              <% if embed.thumbnail_url.present? %>
                <a href="<%= embed.thumbnail_url %>" target="_blank" rel="noopener noreferrer"
                   class="shrink-0 overflow-hidden rounded border border-slate-200 bg-white">
                  <img src="<%= embed.thumbnail_url %>"
                       alt=""
                       loading="lazy"
                       class="w-16 h-16 object-cover block">
                </a>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</article>
