<% content_for :title, "Discord DM Capture — live feed" %>

<%= turbo_stream_from "dms" %>

<%= render "shared/nav" %>

<%# Stale-capture banner: shown only when gateway activity (any frame or
    session event) has gone quiet — meaning the extension itself is stuck
    or the home PC is offline. No DMs ≠ stalled; Discord can just be quiet. %>
<% stale = @last_activity_at && @last_activity_at < 5.minutes.ago %>
<% if stale %>
  <div class="mb-4 px-4 py-3 rounded border border-red-200 bg-red-50 text-red-900 text-sm flex items-start gap-3">
    <span class="text-lg leading-none">⚠</span>
    <div class="flex-1">
      <div class="font-medium">Extension appears offline</div>
      <div class="text-xs text-red-700 mt-0.5">
        No gateway activity for
        <time datetime="<%= @last_activity_at.iso8601 %>" title="<%= @last_activity_at.iso8601 %>">
          <%= time_ago_in_words(@last_activity_at) %>
        </time>.
        Check the home PC, Chrome, and the Discord tab.
      </div>
    </div>
  </div>
<% end %>

<header class="mb-6 border-b border-slate-200 pb-4">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold tracking-tight">Discord DM Capture</h1>
    <span class="text-xs text-slate-500 font-mono">
      <%= ENV["RAILS_ENV"] || Rails.env %>
    </span>
  </div>

  <dl class="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3 text-xs">
    <div>
      <dt class="text-slate-500">Open gateways</dt>
      <dd class="font-medium"><%= @gateways_open %></dd>
    </div>
    <div>
      <dt class="text-slate-500">Last DM</dt>
      <dd class="font-medium">
        <% if @last_message_at %>
          <time datetime="<%= @last_message_at.iso8601 %>" title="<%= @last_message_at.iso8601 %>">
            <%= time_ago_in_words(@last_message_at) %> ago
          </time>
        <% else %>
          <span class="text-slate-400">never</span>
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-slate-500">Last session event</dt>
      <dd class="font-medium">
        <% if @last_session_event %>
          <%= @last_session_event.event %>
          <span class="text-slate-400">
            (<%= time_ago_in_words(@last_session_event.occurred_at) %> ago)
          </span>
        <% else %>
          <span class="text-slate-400">none</span>
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-slate-500">Total DMs captured</dt>
      <dd class="font-medium"><%= DiscordMessage.dms.where(event_type: "MESSAGE_CREATE").count %></dd>
    </div>
  </dl>
</header>

<div id="feed" class="space-y-2">
  <% if @messages.any? %>
    <%= render partial: "discord_messages/discord_message", collection: @messages, as: :message %>
  <% else %>
    <div class="text-sm text-slate-500 italic p-4 border border-dashed border-slate-300 rounded">
      No DMs captured yet. Configure the Chrome extension's <code class="font-mono text-xs bg-slate-100 px-1 py-0.5 rounded">INGEST_URL</code> and API key,
      then receive a DM in Discord. New messages will appear here live.
    </div>
  <% end %>
</div>

<%# Slide-in drawer for the per-channel conversation. Hidden by default;
    the Stimulus controller shows it whenever the inner Turbo Frame loads
    a thread (and hides it when the Close button or Escape fires). %>
<div data-controller="thread-drawer"
     data-thread-drawer-open-class="translate-x-0"
     data-thread-drawer-closed-class="translate-x-full"
     class="fixed inset-0 z-40 pointer-events-none hidden"
     data-thread-drawer-target="root">

  <%# Backdrop — click to close. %>
  <div class="absolute inset-0 bg-slate-900/30 transition-opacity opacity-0"
       data-thread-drawer-target="backdrop"
       data-action="click->thread-drawer#close"
       aria-hidden="true"></div>

  <%# Panel. Slides in from the right via translate-x utilities. %>
  <aside class="absolute top-0 right-0 h-full w-full max-w-md bg-white shadow-2xl
                pointer-events-auto translate-x-full transition-transform duration-200 ease-out
                flex flex-col"
         data-thread-drawer-target="panel"
         role="dialog"
         aria-modal="true"
         aria-label="Conversation">

    <%# The Turbo Frame the dashboard links target. Server renders the
        thread INTO this frame. When the frame is empty, the dashboard
        controller treats the drawer as closed. %>
    <%= turbo_frame_tag :thread_drawer, class: "flex-1 overflow-y-auto",
        data: { thread_drawer_target: "frame" } %>

    <%# Compose bar — sticky at the bottom, always present while drawer is open. %>
    <div class="border-t border-slate-200 p-3 bg-white"
         data-controller="compose"
         data-compose-url-value=""
         data-thread-drawer-target="compose">
      <div class="flex items-end gap-2">
        <textarea
          data-compose-target="input"
          data-action="keydown->compose#onKeydown input->compose#onInput"
          rows="1"
          placeholder="Message…"
          maxlength="2000"
          class="flex-1 resize-none rounded-lg border border-slate-300 px-3 py-2 text-sm
                 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2
                 focus:ring-indigo-500 focus:border-indigo-500 leading-5 max-h-40 overflow-y-auto
                 disabled:opacity-50 disabled:cursor-not-allowed"
        ></textarea>
        <button
          type="button"
          data-compose-target="button"
          data-action="click->compose#send"
          class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg
                 bg-indigo-600 text-white hover:bg-indigo-700 active:bg-indigo-800
                 focus:outline-none focus:ring-2 focus:ring-indigo-500
                 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
          aria-label="Send message"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.897 28.897 0 0 0 15.293-7.155.75.75 0 0 0 0-1.115A28.897 28.897 0 0 0 3.105 2.288Z" />
          </svg>
        </button>
      </div>
      <div data-compose-target="status" class="text-xs text-slate-400 mt-1 hidden"></div>
    </div>
  </aside>
</div>
